# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-strong-random-value

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local dev
MONGO_URI=mongodb://localhost:27017/breachlens
# Production — MongoDB Atlas free tier (M0):
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/breachlens?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-jwt-secret-strong-random-value
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ── Redis (JWT Token Blacklist) ──────────────────────────────────────────────
# Option 1: Full Redis URL (recommended for production)
# JWT_REDIS_URL=redis://localhost:6379/0
# For Redis with TLS (Upstash, Redis Cloud):
#   JWT_REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# Option 2: Individual connection parameters
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Note: If Redis is unavailable, JWT logout will return success but tokens won't be revoked
# Free Redis providers:
#   Upstash Redis (10k commands/day): https://upstash.com
#   Redis Cloud (30MB free): https://redis.com/try-free

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200,http://localhost:3000
# Production example:
# CORS_ORIGINS=https://your-frontend.vercel.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Local dev — in-memory (single process only)
RATELIMIT_STORAGE_URL=memory://
# Production — use Redis for cross-worker consistency.
# Free tier options:
#   Upstash (10k commands/day free): https://upstash.com
#     RATELIMIT_STORAGE_URL=rediss://default:<password>@<host>.upstash.io:6379
#   Redis Cloud (30MB free): https://redis.com/try-free
#     RATELIMIT_STORAGE_URL=redis://:<password>@<host>.cloud.redislabs.com:6379

# ── Request Logging ───────────────────────────────────────────────────────────
REQUEST_IP_POLICY=anonymize
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
IP_ANONYMIZATION_SALT=change-me-unique-salt-value

# ── Audit Logging ─────────────────────────────────────────────────────────────
# Directory for audit logs (JSON format for SIEM integration)
# AUDIT_LOG_DIR=logs
# AUDIT_LOG_FILE=audit.log
# AUDIT_LOG_MAX_BYTES=10485760
# AUDIT_LOG_BACKUP_COUNT=5

# ── Account Security ──────────────────────────────────────────────────────────
# Brute force protection: lock account after N failed login attempts
# MAX_LOGIN_ATTEMPTS=5
# Account lockout duration in seconds (900 = 15 minutes)
# ACCOUNT_LOCKOUT_DURATION=900

# ── Security Headers ──────────────────────────────────────────────────────────
# Content Security Policy - Controls resources the browser can load
# Default is API-friendly and allows Swagger UI to function
# CSP_POLICY=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline';

# X-Frame-Options - Prevents clickjacking attacks
# X_FRAME_OPTIONS=DENY

# Referrer Policy - Controls referrer information sent
# REFERRER_POLICY=strict-origin-when-cross-origin

# Permissions Policy - Restricts access to browser features
# PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()

# HSTS - Force HTTPS (only enable in production with valid SSL certificate)
# ENABLE_HSTS=false
# HSTS_MAX_AGE=31536000
# HSTS_INCLUDE_SUBDOMAINS=true
# HSTS_PRELOAD=false

# ── Password Reset ────────────────────────────────────────────────────────────
# Separate secret for password reset tokens (recommended for security isolation)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PASSWORD_RESET_SECRET=change-me-password-reset-secret-value
# Password reset token expiry in seconds (3600 = 1 hour)
PASSWORD_RESET_TOKEN_EXPIRES=3600

# ── Email Configuration ───────────────────────────────────────────────────────
# Enable email sending (disable in development if no email service configured)
EMAIL_ENABLED=false
# Email backend: console (dev), smtp (production), sendgrid, ses
EMAIL_BACKEND=console
# Sender email address
EMAIL_SENDER=noreply@breachlens.com
# Frontend URL for password reset links
FRONTEND_URL=http://localhost:4200

# SMTP Settings (if using smtp backend)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_USE_TLS=true

# SendGrid Settings (if using sendgrid backend)
# SENDGRID_API_KEY=your-sendgrid-api-key

# AWS SES Settings (if using ses backend)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1

# ── Gunicorn (production) ─────────────────────────────────────────────────────
# Number of worker processes (overrides Procfile default of 4)
# Recommended: (2 × CPU cores) + 1
# WEB_CONCURRENCY=4

# ── Infrastructure & Monitoring ───────────────────────────────────────────────

# ── Logging Configuration ─────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Sentry Error Tracking (Production) ────────────────────────────────────────
# Sign up for free at https://sentry.io (generous free tier)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=production
# Traces sample rate (0.0 to 1.0) - % of transactions to monitor
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Prometheus Metrics ────────────────────────────────────────────────────────
# Enable Prometheus metrics endpoint at /metrics
PROMETHEUS_ENABLED=true

# ── Caching Configuration ─────────────────────────────────────────────────────
# Cache type: SimpleCache (memory), RedisCache, FileSystemCache, NullCache (disabled)
# SimpleCache for localhost, RedisCache for production
CACHE_TYPE=SimpleCache
# Cache timeout in seconds (300 = 5 minutes)
CACHE_DEFAULT_TIMEOUT=300
# Redis URL for caching (if using RedisCache)
# CACHE_REDIS_URL=redis://localhost:6379/1

# ──  MongoDB Connection Pooling ───────────────────────────────────────────────
# Maximum number of connections in pool
MONGO_MAX_POOL_SIZE=50
# Minimum number of connections in pool
MONGO_MIN_POOL_SIZE=10
# Socket timeout in milliseconds
MONGO_SOCKET_TIMEOUT_MS=30000
# Connection timeout in milliseconds
MONGO_CONNECT_TIMEOUT_MS=10000
# Server selection timeout in milliseconds
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
